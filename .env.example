# =============================================================================
  # Agent OS — Environment Variables
  # Copy to .env and fill in required values: cp .env.example .env
  # =============================================================================

  # === Required ===

  # Data directory (absolute path). All persistent data goes here.
  AGENT_DATA=${HOME}/agent-data

  # Postgres password. Generate with: openssl rand -hex 16
  POSTGRES_PASSWORD=

  # Hermes API authentication key. Generate with: openssl rand -hex 32
  API_SERVER_KEY=

  # === Ollama (LLM) ===

  # Main model for Hermes / Honcho reasoning
  # OLLAMA_MODEL=qwen3.6:27b-coding-nvfp4

  # Ollama API URL (services use this to reach host Ollama)
  # Mac: default works. Linux: default works (extra_hosts configured).
  # Remote Ollama: set to http://<ip>:11434
  # OLLAMA_BASE_URL=http://host.docker.internal:11434

  # Ollama host for monitoring dashboard health check (no http://)
  # OLLAMA_HOST=host.docker.internal:11434

  # === Embedding ===

  # Embedding model for Honcho vector search
  # EMBEDDING_MODEL=nomic-embed-text

  # Vector dimensions (must match the embedding model)
  # nomic-embed-text=768, text-embedding-3-small=1536
  # EMBEDDING_DIMS=768

  # === Postgres ===

  # POSTGRES_USER=agentos
  # POSTGRES_DB=agentos

  # === Ports ===

  # HERMES_DASHBOARD_PORT=9119
  # GBRAIN_PORT=3131
  # WEBUI_PORT=8787
  # DASHBOARD_PORT=8080

  # === hermes-webui ===

  # Basic auth password (empty = no auth, localhost only)
  # WEBUI_PASSWORD=

  # Image tag (pin to a release for reproducibility)
  # WEBUI_TAG=latest

  # === Container user ===

  # HERMES_UID=10000
  # HERMES_GID=10000